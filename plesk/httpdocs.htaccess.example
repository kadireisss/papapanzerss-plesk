# Örnek: Plesk "httpdocs" (site kökü) için .htaccess
# Kullanım: İhtiyaç varsa kopyalayıp kökte ".htaccess" adıyla kaydedin veya Apache ek direktiflere taşıyın.
#
# UYARI: PHP-FPM aktifse <IfModule mod_php.c> ve php_value satırları çoğu sunucuda ÇALIŞMAZ veya hata üretir.
# upload_max_filesize vb. için Plesk arayüzünden PHP ayarlarını değiştirin.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # İsteğe bağlı: Censys vb. tarama
    RewriteCond %{HTTP_USER_AGENT} CensysInspect [NC]
    RewriteRule ^ - [F]

    # Temiz URL: dosya/klasör yoksa ve aynı adlı .php varsa
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.*)$ $1.php [NC,L]

    ErrorDocument 404 /BellaMain/404.php
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Veritabanı yerel şifre dosyası (BellaMain/database altında)
<Files "config.local.php">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>
